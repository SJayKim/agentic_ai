# Planner MCP Host 환경 변수

# ==========================================
# LLM API Keys (LiteLLM 통합)
# ==========================================
# 사용하려는 프로바이더의 키만 설정하면 됩니다.
# LiteLLM이 자동으로 올바른 키를 사용합니다.

# Google Gemini (gemini/gemini-2.5-flash 등)
GEMINI_API_KEY=your-gemini-api-key-here

# Anthropic Claude (claude-3-opus-20240229 등)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI (gpt-4o, gpt-4-turbo 등)
OPENAI_API_KEY=your-openai-api-key-here

# DeepSeek (deepseek/deepseek-chat 등)
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Groq (groq/llama3-70b-8192 등)
GROQ_API_KEY=your-groq-api-key-here

# Azure OpenAI (선택사항)
# AZURE_API_KEY=your-azure-api-key-here
# AZURE_API_BASE=https://your-resource.openai.azure.com/
# AZURE_API_VERSION=2024-02-15-preview

# ==========================================
# 기본 LLM 설정
# ==========================================
# LiteLLM 모델 형식: provider/model
# 예: gemini/gemini-2.5-flash, openai/gpt-4o, anthropic/claude-3-opus-20240229
LLM_MODEL=gemini/gemini-2.5-flash

# ==========================================
# 서버 설정
# ==========================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=true

# ==========================================
# MCP Server 연결 (SSE)
# ==========================================
MCP_PLANNER_URL=http://localhost:8001/sse

# ==========================================
# 설정 파일 경로
# ==========================================
CONFIG_PATH=./config/settings.yaml
PROMPTS_DIR=./prompts

# ==========================================
# 로깅
# ==========================================
LOG_LEVEL=INFO

# ==========================================
# Ollama (로컬 LLM - 선택사항)
# ==========================================
# 로컬 Ollama 서버 URL
# OLLAMA_API_BASE=http://localhost:11434

# ==========================================
# LangSmith (LangChain Tracing - 선택사항)
# ==========================================
# LangSmith 트레이싱 활성화
LANGCHAIN_TRACING_V2=true
# LangSmith API 키 (https://smith.langchain.com 에서 발급)
LANGCHAIN_API_KEY=lsv2_pt_xxxxxxxx
# LangSmith 프로젝트 이름
LANGCHAIN_PROJECT=mcp-host-atelier
# LangSmith 엔드포인트 (선택사항, 기본값 사용 권장)
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ==========================================
# Atelier 연동 설정
# ==========================================
# Atelier 스토리지 경로
ATELIER_STORAGE_ROOT=/home/sjkim/workspace/atelier/storage
# Atelier API 베이스 URL
ATELIER_API_BASE_URL=http://localhost:3002/api
# Atelier 에이전트 사용자 ID (Base64 인코딩된 이메일)
# 예: sjkim@plantynet.com -> c2praW1AcGxhbnR5bmV0LmNvbQ==
ATELIER_AGENT_USER_ID=c2praW1AcGxhbnR5bmV0LmNvbQ==
