<node id="Query">
  <data key="d0">Query</data>
  <data key="d1">concept</data>
  <data key="d2">Query is the initial input provided to the RAG system.&lt;SEP&gt;A user question or search term used as input for an RAG system.&lt;SEP&gt;The input request or question provided to the RAG system.</data>
  <data key="d3">chunk-d141f18a9aab4498557bd2c9197355e1&lt;SEP&gt;chunk-04d7b67eb1f5269cf901bd85a6fa243d&lt;SEP&gt;chunk-9b3c51912cd727db72eefcfd4ca93f3b</data>
